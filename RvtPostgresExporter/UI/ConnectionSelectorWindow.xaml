<Window x:Class="RvtPostgresExporter.UI.ConnectionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор подключения" Height="320" Width="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontWeight="Bold" Text="Доступные подключения:" Margin="0,0,0,8"/>

        <ListBox Grid.Row="1" x:Name="ConnectionsList"
                 DisplayMemberPath="Display"
                 SelectionChanged="ConnectionsList_SelectionChanged"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnOk" Content="OK" Width="90" IsEnabled="False" Click="BtnOk_Click" Margin="0,0,8,0"/>
            <Button Content="Отмена" Width="90" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
